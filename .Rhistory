# Load necessary package
library(bootstrap)
# Load the data
data(scor)
head(scor)
# Step 1: Compute the sample correlations
rho12 <- cor(scor$mec, scor$vec)    # ρ̂12 = cor(mechanics, vectors)
rho35 <- cor(scor$alg, scor$sta)    # ρ̂35 = cor(algebra, statistics)
rho15 <- cor(scor$ana, scor$sta)    # ρ̂15 = cor(analysis, statistics)
cat("Sample Correlations:\n")
cat("rho12 (mec, vec):", rho12, "\n")
cat("rho35 (alg, sta):", rho35, "\n")
cat("rho15 (ana, sta):", rho15, "\n\n")
# Step 2: Bootstrap estimates of standard errors
set.seed(123)  # For reproducibility
B <- 2000      # Number of bootstrap replications
n <- nrow(scor)
# Bootstrap correlation function
boot_corr <- function(i, col1, col2) {
cor(scor[i, col1], scor[i, col2])
}
# Generate bootstrap replications
rho12_boot <- replicate(B, boot_corr(sample(1:n, n, replace = TRUE), "mec", "vec"))
rho35_boot <- replicate(B, boot_corr(sample(1:n, n, replace = TRUE), "alg", "sta"))
rho15_boot <- replicate(B, boot_corr(sample(1:n, n, replace = TRUE), "ana", "sta"))
# Compute standard errors
se12 <- sd(rho12_boot)
se35 <- sd(rho35_boot)
se15 <- sd(rho15_boot)
cat("Bootstrap Standard Errors:\n")
cat("SE(rho12):", se12, "\n")
cat("SE(rho35):", se35, "\n")
cat("SE(rho15):", se15, "\n\n")
# Step 3: Compute 95% percentile bootstrap confidence intervals
ci12 <- quantile(rho12_boot, probs = c(0.025, 0.975))
ci35 <- quantile(rho35_boot, probs = c(0.025, 0.975))
